# Station Manager - Environment Variables
# Copy this file to .env and fill in your values

# =============================================================================
# SUPABASE CONFIGURATION (Required)
# =============================================================================

# URL to your Supabase instance
# For local Docker: http://localhost:54321
# For hosted Supabase: https://your-project.supabase.co
VITE_SUPABASE_URL=http://localhost:54321

# Supabase Anonymous/Public Key
# This is safe to expose in the frontend
# Generate using Supabase key generator or get from your Supabase dashboard
VITE_SUPABASE_ANON_KEY=

# =============================================================================
# LOCAL SUPABASE (Only needed if running Supabase in Docker)
# =============================================================================

# PostgreSQL password for the database
POSTGRES_PASSWORD=your-secure-database-password

# JWT Secret for token signing (minimum 32 characters)
# Generate with: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-at-least-32-characters

# Service Role Key (for admin operations)
# Generate using Supabase key generator
SERVICE_ROLE_KEY=

# =============================================================================
# APPLICATION SETTINGS (Optional - can be configured via UI)
# =============================================================================

# Site URL for email redirects
SITE_URL=http://localhost

# =============================================================================
# SMTP CONFIGURATION (Optional - for email verification)
# =============================================================================

# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your-smtp-user
# SMTP_PASS=your-smtp-password
# SMTP_SENDER_NAME=Station Manager
